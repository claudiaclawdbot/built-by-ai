# Stripe — get keys from https://dashboard.stripe.com/apikeys
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_xxx

# Payment Links — create these after getting your secret key:
# Run: node scripts/setup-stripe.js
# Or manually create at https://dashboard.stripe.com/payment-links
NEXT_PUBLIC_STRIPE_PAYMENT_LINK_BASIC=https://buy.stripe.com/xxx
NEXT_PUBLIC_STRIPE_PAYMENT_LINK_STANDARD=https://buy.stripe.com/xxx
NEXT_PUBLIC_STRIPE_PAYMENT_LINK_COMPLEX=https://buy.stripe.com/xxx

# Optional: Supabase for lead database
# Get free credentials at supabase.com
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Optional: GitHub token for auto-creating issues
GITHUB_TOKEN=ghp_your_token_here
